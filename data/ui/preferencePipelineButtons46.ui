<?xml version="1.0"?>
<interface domain="screencsat.extra.feature@wissle.me">
  <requires lib="Gtk" version="4.0"/>
  <requires lib="Adw" version="1.0"/>

  <!-- This is for gnome-shell 46, which does not have AdwButtonRow. -->

  <object class="AdwPreferencesGroup" id="buttons_group"> <!-- Action Buttons only -->
    <property name="margin-top">14</property>

    <child>
      <object class="GtkBox">
        <property name="orientation">GTK_ORIENTATION_VERTICAL</property>
        <property name="spacing">14</property>

        <child>
          <object class="GtkButton">
            <property name="action-name">configures.new</property>
            <property name="height-request">40</property>
            <style>
              <class name="card"/>
            </style>

            <child>
              <object class="AdwButtonContent">
                <property name="label" translatable="yes">Add Pipeline Configure</property>
                <property name="icon-name">list-add-symbolic</property>
              </object>
            </child>

          </object>
        </child>

        <child>
          <object class="GtkButton">
            <property name="action-name">configures.reset</property>
            <property name="height-request">40</property>
            <style>
              <class name="card"/>
            </style>

            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Reset Pipeline Configures to Default</property>
                <!-- Manually apply attributes to look like destructive action -->
                <attributes>
                  <attribute name="weight" value="PANGO_WEIGHT_BOLD"/>
                  <attribute name="foreground" value="red"/>
                </attributes>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

  </object>
</interface>
